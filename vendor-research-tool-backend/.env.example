# ─── Logging ───
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: "text" for human-readable, "json" for structured JSON output
LOG_FORMAT=text

# ─── LLM Provider Configuration ───
# Provider selection (determines which API key is required)
LLM_PROVIDER=openrouter
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_TEMPERATURE=0

# ─── API Keys ───
# Set all keys you have; only the active provider's key is validated at runtime.
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Always required
TAVILY_API_KEY=tvly-xxx

# ─── CORS ───
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── LangSmith Tracing (Optional) ───
# Set LANGSMITH_TRACING=true and fill in the API key to enable tracing.
# Leave as false (default) if you don't have a LangSmith account.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=vendor-research-tool
